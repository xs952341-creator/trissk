# ===========================================
# CONFIGURAÇÕES OBRIGATÓRIAS
# ===========================================

# URL da aplicação (ex: https://seu-dominio.com)
NEXT_PUBLIC_APP_URL=

# Supabase - Database e Auth
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe - Pagamentos
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ===========================================
# CONFIGURAÇÕES DE CRON E SEGURANÇA
# ===========================================

# Segredo para tarefas cron (gerar string aleatória)
CRON_SECRET=

# Inngest - Automação e Workflows
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=

# ===========================================
# CONFIGURAÇÕES DE CACHE E PERFORMANCE
# ===========================================

# Redis/Upstash para cache
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===========================================
# CONFIGURAÇÕES DE MONITORAMENTO
# ===========================================

# Sentry - Error Tracking
SENTRY_DSN=

# Datadog - Monitoring (opcional)
DD_API_KEY=

# ===========================================
# CONFIGURAÇÕES DE EMAIL E NOTIFICAÇÕES
# ===========================================

# Resend - Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Web Push Notifications
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
VAPID_PUBLIC_KEY=

# ===========================================
# CONFIGURAÇÕES DE INTEGRAÇÕES
# ===========================================

# Pagar.me - Pagamentos BR
PAGARME_API_KEY=
PAGARME_ENCRYPTION_KEY=

# eNotas - Nota Fiscal
ENOTAS_API_KEY=
ENOTAS_COMPANY_ID=

# ===========================================
# CONFIGURAÇÕES DE DESENVOLVIMENTO
# ===========================================

# Ambiente (development | production)
NODE_ENV=development

# Porta do servidor (padrão: 3000)
PORT=3000

# ===========================================
# INSTRUÇÕES
# ===========================================
# 1. Copie este arquivo para .env.local
# 2. Preencha todas as variáveis obrigatórias
# 3. Nunca commit o arquivo .env.local
# 4. Mantenha segredos seguros em produção
