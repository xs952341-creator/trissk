{
  "crons": [
    {
      "path": "/api/cron/process-jobs",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/dunning",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/marketing",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/analytics-snapshot",
      "schedule": "0 2 1 * *"
    },
    {
      "path": "/api/cron/chargeback-watchdog",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/reconcile",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/saas-health-check",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/renewal-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/emit-fiscal-jobs",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/onboarding-emails",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/expire-referrals",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/usage-to-stripe",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/release-holds",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/retry-failed-deliveries",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/churn-recovery",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/health-score-batch",
      "schedule": "0 1-23/6 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "on"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    }
  ]
}